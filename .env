# Duración del examen en minutos.
# Vite incrusta este valor en el bundle en tiempo de build.
# Usa un número decimal para fracciones (ej: 0.5 = 30 segundos).
# Setear en 0 para deshabilitar el límite de tiempo.
VITE_EXAM_DURATION_MINUTES=100

# URL del Google Form para feedback. Dejar vacío para ocultar el botón.
VITE_FEEDBACK_FORM_URL=https://docs.google.com/forms/d/e/1FAIpQLSdmRFt2U0b0HQ9gsJYsz4D4_kYrXbGlkKnzcTn8EruiMgg_qw/viewform?usp=publish-editor
